---
---

<div class="cover">
  <div class="cover__border">
    <div class="cover__stamp">50</div>
    <div class="cover__center">
      <span class="cover__title">THE FIFTY STANDARD</span>
      <span class="cover__subtitle">Thirty workouts for strength, lungs, and durability</span>
    </div>
    <span class="cover__edition">Edition 01 — 2026</span>
  </div>
</div>

<style>
  .cover {
    aspect-ratio: 8.5 / 11;
    background-color: var(--bg-tertiary);
    padding: 8px;
    width: 100%;
    max-width: 360px;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.08);
  }

  .cover__border {
    border: 1px solid var(--border);
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }

  .cover__stamp {
    position: absolute;
    top: 16px;
    left: 16px;
    width: 36px;
    height: 36px;
    border: 2px solid var(--charcoal);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: 16px;
    color: var(--charcoal);
    line-height: 1;
  }

  .cover__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .cover__title {
    font-family: var(--font-headline);
    font-weight: 900;
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    letter-spacing: -0.01em;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--charcoal);
  }

  .cover__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    color: var(--warm-gray);
    line-height: 1.4;
    max-width: 220px;
  }

  .cover__edition {
    position: absolute;
    bottom: 12px;
    right: 16px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 400;
    color: var(--light-gray);
    letter-spacing: 0.04em;
  }
</style>
