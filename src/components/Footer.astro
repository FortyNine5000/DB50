---
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__col">
      <span class="footer__brand">THE FIFTY STANDARD</span>
      <span class="footer__tagline">The pair. The work. The standard.</span>
    </div>
    <div class="footer__col footer__col--center">
      <a href="https://instagram.com/thefiftystandard" class="footer__link" target="_blank" rel="noopener">@thefiftystandard</a>
    </div>
    <div class="footer__col footer__col--right">
      <span class="footer__copyright">&copy; 2026 The Fifty Standard</span>
    </div>
  </div>
  <div class="footer__email container">
    <form class="footer__form" action="#" method="post">
      <input type="email" class="footer__input" placeholder="Your email" required />
      <button type="submit" class="footer__notify">NOTIFY ME</button>
    </form>
    <p class="footer__caption">Get notified when new editions and the printed field manual drop.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 40px 0 32px;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: start;
    gap: 24px;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .footer__col--center {
    text-align: center;
  }

  .footer__col--right {
    text-align: right;
  }

  .footer__brand {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--light-gray);
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 13px;
    color: var(--light-gray);
  }

  .footer__link {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--light-gray);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--charcoal);
    text-decoration: underline;
  }

  .footer__copyright {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--light-gray);
  }

  .footer__email {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .footer__form {
    display: flex;
    max-width: 400px;
    width: 100%;
  }

  .footer__input {
    flex: 1;
    border: 1px solid var(--border);
    border-right: none;
    background-color: var(--bg-primary);
    padding: 10px 16px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--charcoal);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .footer__input::placeholder {
    color: var(--light-gray);
  }

  .footer__input:focus {
    border-color: var(--olive);
  }

  .footer__notify {
    background-color: var(--rust);
    color: var(--button-text);
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 20px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .footer__notify:hover {
    background-color: var(--rust-hover);
  }

  .footer__caption {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--light-gray);
    margin-top: 10px;
    text-align: center;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 16px;
    }

    .footer__col--center,
    .footer__col--right {
      text-align: center;
    }

    .footer__form {
      max-width: 100%;
    }

    .footer__caption {
      font-size: 10px;
    }
  }
</style>
