---
interface Props {
  checkoutUrl: string;
}
const { checkoutUrl } = Astro.props;
---

<section class="cta-final section reveal">
  <div class="cta-final__inner container">
    <h2 class="cta-final__headline">ONE HARD MONTH. ONE PAIR OF DUMBBELLS.</h2>
    <p class="cta-final__sub-headline">START THE STANDARD.</p>
    <div class="cta-final__buttons">
      <a href={checkoutUrl} class="cta-button cta-final__button">DIGITAL — $29</a>
    </div>
    <p class="cta-final__field-manual">Printed field manual edition coming soon.</p>
    <p class="cta-final__credibility">Designed, tested, and programmed by a strength and conditioning practitioner.</p>
    <p class="cta-final__fine-print">One payment. No subscription. 30-day money-back guarantee.</p>
  </div>
</section>

<style>
  .cta-final__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-final__headline {
    margin-bottom: 8px;
  }

  .cta-final__sub-headline {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--olive);
    margin-bottom: 32px;
  }

  .cta-final__buttons {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta-final__button {
    font-size: 18px;
    padding: 20px 52px;
  }

  .cta-final__field-manual {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--light-gray);
    margin-top: 12px;
    letter-spacing: 0.02em;
  }

  .cta-final__credibility {
    font-family: var(--font-body);
    font-size: 15px;
    font-style: italic;
    color: var(--light-gray);
    margin-top: 24px;
  }

  .cta-final__fine-print {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--light-gray);
    margin-top: 8px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .cta-final__buttons {
      flex-direction: column;
      width: 100%;
    }

    .cta-final__button {
      width: 100%;
      text-align: center;
      max-width: 400px;
    }
  }
</style>
