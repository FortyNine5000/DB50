---
interface Props {
  checkoutUrl: string;
}
const { checkoutUrl } = Astro.props;
---

<section class="hero section">
  <div class="hero__inner container">
    <h1 class="hero-stagger">THE FIFTY STANDARD</h1>
    <p class="hero__tagline hero-stagger">One hard month.</p>
    <p class="hero__detail hero-stagger">
      Bodyweight and one pair of 50 lb dumbbells.<br />
      Four weeks of structured training that gets harder every week.<br />
      When you finish, you've done the work.
    </p>
    <p class="hero__edge hero-stagger">SIMPLE SETUP. TOUGH SESSIONS.</p>
    <a href={checkoutUrl} class="cta-button hero-stagger">START THE STANDARD — $29</a>
    <span class="hero__price hero-stagger">One payment. Yours forever.</span>
  </div>
</section>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: 64px;
    text-align: center;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero h1 {
    font-size: clamp(56px, 10vw, 110px);
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
    margin-bottom: 24px;
  }

  .hero .cta-button {
    font-size: 17px;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 400;
    color: var(--warm-gray);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .hero__detail {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: var(--warm-gray);
    line-height: 1.6;
    max-width: var(--text-width);
    margin-bottom: 28px;
  }

  .hero__edge {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    letter-spacing: 0.15em;
    color: var(--olive);
    margin-bottom: 32px;
  }

  .hero__price {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--light-gray);
    margin-top: 16px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 120px;
      padding-bottom: 48px;
    }
  }
</style>
