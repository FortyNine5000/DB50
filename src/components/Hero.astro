---
// No props needed — hero uses inline email capture in pre-launch mode
---

<section class="hero section">
  <div class="hero__inner container">
    <h1 class="hero-stagger">THE FIFTY STANDARD</h1>
    <p class="hero__tagline hero-stagger">One hard month.</p>
    <p class="hero__detail hero-stagger">
      Bodyweight and one pair of 50 lb dumbbells.<br />
      Four weeks of structured training that gets harder every week.<br />
      When you finish, you've done the work.
    </p>
    <p class="hero__edge hero-stagger">SIMPLE SETUP. TOUGH SESSIONS.</p>
    <form class="hero__form hero-stagger" action="https://buttondown.com/api/emails/embed-subscribe/DB50" method="post">
      <input type="hidden" value="1" name="embed" />
      <input type="email" name="email" class="hero__input" placeholder="Your email" required />
      <button type="submit" class="hero__notify">GET NOTIFIED</button>
    </form>
    <span class="hero__price hero-stagger">Launching soon. Be the first to know.</span>
  </div>
</section>

<style>
  .hero {
    padding-top: 160px;
    padding-bottom: 64px;
    text-align: center;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero h1 {
    font-size: clamp(56px, 10vw, 110px);
    line-height: 0.85;
    letter-spacing: -0.02em;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.04);
    margin-bottom: 24px;
  }

  .hero__tagline {
    font-family: var(--font-body);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 400;
    color: var(--warm-gray);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .hero__detail {
    font-family: var(--font-body);
    font-size: 17px;
    font-weight: 400;
    color: var(--warm-gray);
    line-height: 1.6;
    max-width: var(--text-width);
    margin-bottom: 28px;
  }

  .hero__edge {
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    letter-spacing: 0.15em;
    color: var(--olive);
    margin-bottom: 32px;
  }

  .hero__form {
    display: flex;
    max-width: 420px;
    width: 100%;
  }

  .hero__input {
    flex: 1;
    border: 1px solid var(--border);
    border-right: none;
    background-color: var(--bg-primary);
    padding: 14px 18px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--charcoal);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .hero__input::placeholder {
    color: var(--light-gray);
  }

  .hero__input:focus {
    border-color: var(--olive);
  }

  .hero__notify {
    background-color: var(--rust);
    color: var(--button-text);
    font-family: var(--font-headline);
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 14px 28px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
    white-space: nowrap;
  }

  .hero__notify:hover {
    background-color: var(--rust-hover);
  }

  .hero__price {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--light-gray);
    margin-top: 16px;
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 120px;
      padding-bottom: 48px;
    }

    .hero__form {
      max-width: 100%;
    }
  }
</style>
